{
  "name": "opencut",
  "version": "0.2.0-ts.0",
  "description": "AI-powered video clipping CLI. Transcribes media, extracts highlights via LLM, exports subtitles/timelines/burned-in video.",
  "type": "module",
  "bin": {
    "opencut": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.2",
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target=node --outfile=dist/cli.js --banner=\"#!/usr/bin/env node\" && bun build src/index.ts --target=node --outfile=dist/index.js && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "bun test"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "openai": "^6.38.0",
    "smart-whisper": "^0.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
